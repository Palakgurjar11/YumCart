# MongoDB connection (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/yumcart

# JWT secret — use a long random string in production
JWT_SECRET=change-this-to-a-secure-secret-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# Optional: first admin bootstrap (seed uses admin@yumcart.com — set strong password via app after first login in prod)
ADMIN_EMAIL=admin@yumcart.com
